{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdl-skill.local/schemas/revision-plan.schema.json",
  "title": "Revision Plan",
  "type": "object",
  "required": ["learner_id", "generated_at", "tasks"],
  "properties": {
    "learner_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "concept", "priority", "task_type", "prompt", "due_at"],
        "properties": {
          "id": { "type": "string" },
          "concept": { "type": "string" },
          "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
          "task_type": {
            "type": "string",
            "enum": ["active_recall", "implementation", "explain", "compare", "debug", "apply", "resource_retrieval"]
          },
          "prompt": { "type": "string" },
          "reason": { "type": "string" },
          "due_at": { "type": "string", "format": "date-time" },
          "status": {
            "type": "string",
            "enum": ["scheduled", "completed", "skipped"]
          }
        }
      }
    }
  }
}
